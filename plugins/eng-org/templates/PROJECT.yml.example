# PROJECT.yml — eng-org configuration record
# Lives at the root of every project that uses eng-org.
# Generated by /eng-org:init. Edited by hand only when adding/removing
# domains. /eng-org:update reads this to know what to regenerate.

name: my-project
framework_version: "0.1.0"

stack:
  backend: node-trpc-drizzle      # node-trpc-drizzle | nextjs-prisma | django | rails | go | none
  frontend: expo-rn               # expo-rn | nextjs | nuxt | sveltekit | none

# Tech Leads — one TL agent generated per domain
domains:
  - id: auth
    title: Auth
    owns:
      - backend/src/trpc/routers/auth.ts
      - backend/src/lib/{jwt,otp}.ts
      - mobile/lib/auth.ts
      - mobile/app/(auth)/*
    db_tables: [users, otpCodes, refreshTokens]
    hazards:
      - PII (email, phone) in logs without scrub
      - Missing rate limit on auth endpoints
      - OTP timing attacks (constant-time compare required)
      - Session fixation
      - Mobile secret in AsyncStorage instead of SecureStore

  - id: billing
    title: Billing
    owns:
      - backend/src/trpc/routers/billing.ts
      - backend/src/domain/pricing.ts
    db_tables: [invoices, payments]
    hazards:
      - Money math without integer cents
      - Idempotency missing on payment webhooks
      - Race on concurrent charge

# Specialists shipped by the eng-org plugin (referenced, not redefined)
specialists:
  devs:      [postgres-drizzle, trpc, domain, expo-rn, ui-animation]
  tests:     [unit, integration, e2e, regression, load]
  reviewers: [architecture, security, performance, standards, observability]

# Triage rules — what counts as Mode A vs Mode B for /eng-org:em-intake
triage:
  mode_a_paths:
    - governance/**
    - .claude/**
    - "**/*.md"
    - PROJECT.yml
  mode_b_paths:
    - mobile/**
    - backend/**
    - "**/schema.ts"
    - "**/migrations/**"
    - package.json
    - pyproject.toml
    - go.mod
